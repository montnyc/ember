{
  "name": "@montnyc/ember",
  "version": "0.5.0",
  "type": "module",
  "description": "PRD-driven autonomous coding loop tool",
  "bin": {
    "ember": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --outfile=dist/cli.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx oxlint src/",
    "fmt": "bunx oxfmt .",
    "fmt:check": "bunx oxfmt --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/montnyc/ember.git"
  },
  "keywords": ["ralph-loop"],
  "author": "montnyc",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "latest",
    "typescript": "^5.8.0"
  }
}
